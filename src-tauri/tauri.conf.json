{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TooEasy",
  "version": "1.3.4",
  "identifier": "app.tooeasy.mac",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "gallery",
        "title": "TooEasy",
        "url": "index.html",
        "width": 940,
        "height": 640,
        "center": true,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "visible": false,
        "shadow": false,
        "windowEffects": {
          "effects": ["popover"],
          "state": "active",
          "radius": 30
        }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/TooEasy/**"]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["icons/tray-icon.png"]
  }
}
