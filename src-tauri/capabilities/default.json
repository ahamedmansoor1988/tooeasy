{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "TooEasy default capabilities",
  "windows": ["gallery", "panel"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "opener:default",
    "fs:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load"
  ]
}
